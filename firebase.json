          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "streamdotfinance",
          "configurations": {
            "android": "1:827237908922:android:8e427ad2259e6ce5d81d83",
            "ios": "1:827237908922:ios:42a3e1a6adb66662d81d83",
